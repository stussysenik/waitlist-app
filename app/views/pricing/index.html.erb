<div class="mx-auto max-w-4xl px-6 py-16">
  <div class="text-center">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900">Simple, transparent pricing</h1>
    <p class="mt-4 text-lg text-gray-600">Start free, scale as you grow.</p>
  </div>

  <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-3">
    <!-- Free -->
    <div class="rounded-2xl bg-white p-8 ring-1 ring-gray-200 hover-lift">
      <h3 class="text-lg font-semibold text-gray-900">Free</h3>
      <p class="mt-2 text-sm text-gray-500">Perfect for testing the waters.</p>
      <p class="mt-6"><span class="text-4xl font-bold text-gray-900">$0</span><span class="text-sm text-gray-500">/month</span></p>
      <ul class="mt-8 space-y-3 text-sm text-gray-600">
        <li class="flex gap-x-3">
          <svg class="h-5 w-5 text-brand-600" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          1 waitlist
        </li>
        <li class="flex gap-x-3">
          <svg class="h-5 w-5 text-brand-600" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          100 subscribers
        </li>
        <li class="flex gap-x-3">
          <svg class="h-5 w-5 text-brand-600" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          Referral system
        </li>
      </ul>
      <% if authenticated? && current_user.free? %>
        <div class="mt-8">
          <span class="block w-full rounded-lg bg-gray-100 px-4 py-2.5 text-center text-sm font-semibold text-gray-600">Current plan</span>
        </div>
      <% else %>
        <div class="mt-8">
          <%= link_to "Get started", new_registration_path, class: "block w-full rounded-lg bg-brand-50 px-4 py-2.5 text-center text-sm font-semibold text-brand-600 hover:bg-brand-100 transition-colors" %>
        </div>
      <% end %>
    </div>

    <!-- Starter - Most popular with gradient border -->
    <div class="rounded-2xl bg-white p-8 relative gradient-border shine hover-lift">
      <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-gradient-to-r from-brand-500 to-accent-500 px-3 py-1 text-xs font-semibold text-white shadow-lg shadow-brand-500/25">Most popular</span>
      <h3 class="text-lg font-semibold text-gray-900">Starter</h3>
      <p class="mt-2 text-sm text-gray-500">For serious launches.</p>
      <p class="mt-6"><span class="text-4xl font-bold text-gray-900">$29</span><span class="text-sm text-gray-500">/month</span></p>
      <ul class="mt-8 space-y-3 text-sm text-gray-600">
        <li class="flex gap-x-3">
          <svg class="h-5 w-5 text-brand-600" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          5 waitlists
        </li>
        <li class="flex gap-x-3">
          <svg class="h-5 w-5 text-brand-600" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          5,000 subscribers
        </li>
        <li class="flex gap-x-3">
          <svg class="h-5 w-5 text-brand-600" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          CSV export
        </li>
        <li class="flex gap-x-3">
          <svg class="h-5 w-5 text-brand-600" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          Remove branding
        </li>
      </ul>
      <div class="mt-8">
        <%= form_with url: subscription_path, method: :post do |f| %>
          <%= f.hidden_field :plan, value: "starter" %>
          <%= f.submit "Subscribe", class: "block w-full rounded-lg bg-gradient-to-r from-brand-500 to-accent-500 px-4 py-2.5 text-center text-sm font-semibold text-white shadow-lg shadow-brand-500/25 hover:shadow-brand-500/40 cursor-pointer transition-all hover:scale-[1.02]" %>
        <% end %>
      </div>
    </div>

    <!-- Pro -->
    <div class="rounded-2xl bg-white p-8 ring-1 ring-gray-200 hover-lift">
      <h3 class="text-lg font-semibold text-gray-900">Pro</h3>
      <p class="mt-2 text-sm text-gray-500">Unlimited everything.</p>
      <p class="mt-6"><span class="text-4xl font-bold text-gray-900">$99</span><span class="text-sm text-gray-500">/month</span></p>
      <ul class="mt-8 space-y-3 text-sm text-gray-600">
        <li class="flex gap-x-3">
          <svg class="h-5 w-5 text-brand-600" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          Unlimited waitlists
        </li>
        <li class="flex gap-x-3">
          <svg class="h-5 w-5 text-brand-600" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          Unlimited subscribers
        </li>
        <li class="flex gap-x-3">
          <svg class="h-5 w-5 text-brand-600" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          Priority support
        </li>
        <li class="flex gap-x-3">
          <svg class="h-5 w-5 text-brand-600" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          API access
        </li>
      </ul>
      <div class="mt-8">
        <%= form_with url: subscription_path, method: :post do |f| %>
          <%= f.hidden_field :plan, value: "pro" %>
          <%= f.submit "Subscribe", class: "block w-full rounded-lg bg-gray-900 px-4 py-2.5 text-center text-sm font-semibold text-white hover:bg-gray-800 cursor-pointer transition-colors" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
