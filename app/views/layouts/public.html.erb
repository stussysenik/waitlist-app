<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "WaitlistApp" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:meta_description).presence || 'Create viral waitlist landing pages. Collect emails, enable referrals, and track growth.' %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= meta_tags %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-white">
    <%= yield %>
  </body>
</html>
