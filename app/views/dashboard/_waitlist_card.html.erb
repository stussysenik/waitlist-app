<%= link_to waitlist_path(waitlist), class: "block rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5 hover:ring-indigo-500/20 hover:shadow-md transition" do %>
  <div class="flex items-center justify-between">
    <h4 class="text-sm font-semibold text-gray-900 truncate"><%= waitlist.name %></h4>
    <%= status_badge(waitlist.status) %>
  </div>
  <p class="mt-2 text-sm text-gray-500 line-clamp-2"><%= waitlist.headline.presence || "No headline set" %></p>
  <div class="mt-4 flex items-center gap-x-4 text-xs text-gray-500">
    <div class="flex items-center gap-x-1">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
      </svg>
      <%= number_with_delimiter(waitlist.subscribers_count) %> subscribers
    </div>
    <div class="text-gray-300">|</div>
    <div>/<%= waitlist.slug %></div>
  </div>
<% end %>
