<div class="space-y-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
      <p class="mt-1 text-sm text-gray-500">Welcome back, <%= current_user.name %>. Here's how your waitlists are doing.</p>
    </div>
    <%= link_to new_waitlist_path, class: "inline-flex items-center gap-x-2 rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      New Waitlist
    <% end %>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
    <%= render "stat_card", title: "Total Subscribers", value: number_with_delimiter(@total_subscribers), change: nil, icon: "users" %>
    <%= render "stat_card", title: "This Week", value: number_with_delimiter(@recent_subscribers), change: nil, icon: "trending" %>
    <%= render "stat_card", title: "Active Waitlists", value: @waitlists.active.count, change: nil, icon: "list" %>
  </div>

  <!-- Chart -->
  <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5" data-controller="chart">
    <h3 class="text-base font-semibold text-gray-900">Subscriber Growth (30 days)</h3>
    <div class="mt-4" style="height: 300px">
      <% if @chart_data.any? %>
        <%= line_chart @chart_data, colors: ["#4F46E5"], library: { plugins: { legend: { display: false } } } %>
      <% else %>
        <div class="flex h-full items-center justify-center text-gray-400">
          <p>No subscriber data yet. Create a waitlist to get started.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent Waitlists -->
  <div>
    <h3 class="text-base font-semibold text-gray-900 mb-4">Your Waitlists</h3>
    <% if @waitlists.any? %>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <%= render partial: "waitlist_card", collection: @waitlists, as: :waitlist, cached: true %>
      </div>
    <% else %>
      <div class="rounded-xl border-2 border-dashed border-gray-300 p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
        <h3 class="mt-2 text-sm font-semibold text-gray-900">No waitlists yet</h3>
        <p class="mt-1 text-sm text-gray-500">Get started by creating your first waitlist.</p>
        <div class="mt-6">
          <%= link_to "Create Waitlist", new_waitlist_path, class: "inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
