<h1 class="text-2xl font-bold text-gray-900 text-center">Sign in to your account</h1>

<%= form_with url: session_url, class: "mt-8 space-y-5" do |form| %>
  <div>
    <label for="email_address" class="block text-sm font-medium text-gray-700">Email address</label>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "you@example.com", value: params[:email_address], class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>

  <div>
    <label for="password" class="block text-sm font-medium text-gray-700">Password</label>
    <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>

  <div class="flex items-center justify-between">
    <%= form.submit "Sign in", class: "w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
  </div>

  <div class="text-center text-sm text-gray-500">
    <%= link_to "Forgot password?", new_password_path, class: "text-indigo-600 hover:text-indigo-500" %>
    <span class="mx-2">|</span>
    <%= link_to "Create an account", new_registration_path, class: "text-indigo-600 hover:text-indigo-500" %>
  </div>
<% end %>
