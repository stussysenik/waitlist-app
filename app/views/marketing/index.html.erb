<!-- Navbar - Glass morphism -->
<nav class="fixed top-0 z-50 w-full bg-white/70 backdrop-blur-xl border-b border-gray-200/50">
  <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-x-2">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-500 to-accent-500 shadow-lg shadow-brand-500/25">
        <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z" />
        </svg>
      </div>
      <span class="text-xl font-bold tracking-tight">
        <span class="text-gray-900">Waitlist</span><span class="text-brand-500">App</span>
      </span>
    </div>
    <div class="flex items-center gap-x-6">
      <%= link_to "Pricing", pricing_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" %>
      <%= link_to "Sign in", new_session_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" %>
      <%= link_to "Get started free", new_registration_path, class: "rounded-lg bg-gradient-to-r from-brand-500 to-accent-500 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-brand-500/25 hover:shadow-brand-500/40 hover:scale-[1.02] transition-all" %>
    </div>
  </div>
</nav>

<!-- Hero - Mesh gradient background -->
<div class="relative isolate pt-32 pb-20 overflow-hidden">
  <!-- Mesh gradient orbs -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-brand-400/30 blur-3xl" style="animation: mesh-pulse 8s ease-in-out infinite;"></div>
    <div class="absolute top-1/3 right-1/4 w-80 h-80 rounded-full bg-accent-400/20 blur-3xl" style="animation: mesh-pulse 10s ease-in-out infinite 2s;"></div>
    <div class="absolute bottom-1/4 left-1/3 w-72 h-72 rounded-full bg-blue-400/15 blur-3xl" style="animation: mesh-pulse 12s ease-in-out infinite 4s;"></div>
    <!-- Dot grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #000 1px, transparent 1px); background-size: 24px 24px;"></div>
  </div>

  <div class="mx-auto max-w-3xl px-6 text-center">
    <!-- Live beta badge with ping -->
    <div class="inline-flex items-center gap-x-2 rounded-full bg-brand-50 px-4 py-1.5 text-sm font-medium text-brand-700 mb-8 ring-1 ring-brand-200">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-500"></span>
      </span>
      Now in public beta
    </div>

    <h1 class="text-5xl font-extrabold tracking-tight text-gray-900 sm:text-7xl leading-[1.1]">
      Launch your product with a <span class="gradient-text">viral waitlist</span>
    </h1>

    <p class="mt-6 text-lg leading-8 text-gray-600 max-w-2xl mx-auto">
      Create beautiful waitlist landing pages in minutes. Collect emails, enable referrals,
      and watch your audience grow with real-time analytics. No coding required.
    </p>

    <div class="mt-10 flex items-center justify-center gap-x-6">
      <%= link_to new_registration_path, class: "shine rounded-xl bg-gradient-to-r from-brand-500 to-accent-500 px-8 py-3.5 text-sm font-semibold text-white shadow-lg shadow-brand-500/25 hover:shadow-brand-500/40 hover:scale-[1.02] transition-all" do %>
        Start for free
      <% end %>
      <%= link_to pricing_path, class: "text-sm font-semibold text-gray-900 flex items-center gap-x-2 hover:text-brand-600 transition-colors" do %>
        View pricing
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      <% end %>
    </div>

    <!-- Social proof bar -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-gray-500">
      <div class="flex items-center gap-x-1.5">
        <svg class="h-4 w-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
        </svg>
        No credit card required
      </div>
      <div class="flex items-center gap-x-1.5">
        <svg class="h-4 w-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
        </svg>
        2 minute setup
      </div>
      <div class="flex items-center gap-x-1.5">
        <svg class="h-4 w-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
        </svg>
        No coding needed
      </div>
    </div>
  </div>
</div>

<!-- Features -->
