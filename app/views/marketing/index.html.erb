    </div>

    <div class="rounded-2xl bg-white p-8 shadow-sm ring-1 ring-gray-100 hover-lift">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-purple-50 to-fuchsia-50">
        <svg class="h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
