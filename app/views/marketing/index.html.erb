<!-- CTA -->
<div class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-600 via-brand-600 to-accent-600"></div>
  <div class="absolute inset-0 noise-texture opacity-50"></div>
  <div class="relative py-20">
    <div class="mx-auto max-w-2xl text-center px-6">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Ready to launch?</h2>
      <p class="mt-4 text-lg text-brand-100">Create your first waitlist in under 2 minutes. No credit card required.</p>
      <div class="mt-8">
        <%= link_to "Get started free", new_registration_path, class: "shine rounded-xl bg-white px-8 py-3.5 text-sm font-semibold text-brand-600 shadow-lg hover:bg-brand-50 transition-all hover:scale-[1.02]" %>
      </div>
    </div>
  </div>
</div>

<!-- Footer -->
<footer class="bg-gray-50 py-12">
  <div class="mx-auto max-w-7xl px-6 text-center">
    <p class="text-sm text-gray-500">&copy; <%= Date.current.year %> WaitlistApp. Built with Rails 8.</p>
  </div>
</footer>
